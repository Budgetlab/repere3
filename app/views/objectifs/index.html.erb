<% content_for :title do %>Ajout objectifs | REPERE3 <% end %>
<main role="main" class="containtAll">
  <div class="fr-container fr-mt-7w">
    <div class="fr-col-lg-10 fr-col-offset-lg-1">
      <h1>Ajouter un nouveau document</h1>
     	<div>
      	<%= form_tag import_objectifs_path, multipart: true do %>
      	<div class="fr-upload-group">
		    <label class="fr-label" for="file-upload">Ajouter des fichiers
		        <span class="fr-hint-text">Taille maximale : 500 Mo. Formats supportés : xlsx. </span>
		    </label>
		    <%= file_field_tag  :file, accept: '.xlsx', class: "fr-upload", id: "file-upload" %>
				</div>
        <div class="fr-my-4w"><%= submit_tag "Transmettre", class:"fr-btn" %></div>
        <% end %>
    	</div>

      <div class="fr-table fr-mt-4w" id="table-objectifs-component">
        <div class="fr-table__wrapper">
          <div class="fr-table__container">
            <div class="fr-table__content">
              <table id="table-objectifs">
                <caption>Objectifs par année</caption>
                <thead>
                  <tr>
                    <th>Année</th>
                    <th>Nombre d'objectifs</th>
                  </tr>
                </thead>
                <tbody>
                  <% @objectifs_par_annee.each_with_index do |(annee, nombre), index| %>
                    <tr id="table-objectifs-row-key-<%= index + 1 %>" data-row-key="<%= index + 1 %>">
                      <td><%= annee %></td>
                      <td><%= nombre %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
		</div>
	</div>
</main>